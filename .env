# ── Environment variables for QLDA_Jems ───────────────────────────────────────
# Copy this file to .env and adjust values for your environment.
# Do NOT commit this file with real secrets.

# Flask
SECRET_KEY=change-this-to-a-random-secret-in-production
FLASK_DEBUG=true
PORT=5020

# Database
DB_FILE=projects.db

# Directories (relative to app root)
MAIL_DIR=mail
PROJECT_DIR=project
OLD_DIR=old
FILEUPLOAD_DIR=fileupload
